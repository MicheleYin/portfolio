---
import { MessageCircleCode, Pickaxe } from "@lucide/astro";
---

<footer class="footer footer-horizontal footer-center bg-base-200 py-10">
  <aside>
    <MessageCircleCode class="inline-block size-20" />
    <p class="max-w-xl m-auto text-lg">
      DM me on Linkedin<a
        href="https://www.linkedin.com/in/michele-yin/"
        class="link link-hover text-primary">michele-yin</a
      >
    </p>
    <p class="text-base-content/60">
      Copyright © {new Date().getFullYear()} - Crafted by an Artisan <a
        class="link"
        href="https://lauroguedes.dev"
        target="_blank"
        ><Pickaxe class="size-3 inline-block mr-1" />Lauro Guedes</a
      >
    </p>
  </aside>
</footer>
